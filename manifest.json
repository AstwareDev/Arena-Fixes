{
  "manifest_version": 3,
  "name": "Arena Fixes",
  "version": "2.0.0",
  "description": "Enhances Arena.AI with UI fixes, auto-scrolling, prompt improvements, a custom theme, and other quality-of-life features.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://arena.ai/*",
    "https://*.arena.ai/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Arena Fixes",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://arena.ai/*",
        "https://*.arena.ai/*"
      ],
      "js": ["content.js", "src/features/enhance-prompt/client.js", "src/features/model-starring/client.js"],
      "type": "module",
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lmarena.png",
        "src/**/*.js" 
      ],
      "matches": ["https://arena.ai/*", "https://*.arena.ai/*"]
    }
  ]
}